# Production environment variables (Railway)
# Set these in the Railway dashboard under your service → Variables.
# Do NOT commit real values — .env.production is gitignored.

# --- Database -------------------------------------------------------------
DB_TYPE=postgres
# Provided automatically when you add a Railway Postgres plugin. Reference it as:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<database>

# --- App ------------------------------------------------------------------
# Generate a strong key, e.g.  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<generate-a-strong-random-key>
# Enables secure (HTTPS-only) session cookies. Railway terminates TLS for you.
FLASK_ENV=production
# 'false' = picks lock on the production schedule; 'true' = always editable.
ALLOW_UNRESTRICTED_EDITS=false

# --- Scheduled jobs (optional) -------------------------------------------
# Shared secret required by /api/cron/* endpoints. Send it from your cron
# trigger as:  Authorization: Bearer <CRON_SECRET>
CRON_SECRET=<generate-a-strong-random-key>

# NOTE: PORT is injected by Railway — do not set it. gunicorn binds $PORT.
